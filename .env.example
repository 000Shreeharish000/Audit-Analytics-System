APP_NAME=Decision & Financial Digital Twin Platform
APP_ENV=local
APP_VERSION=1.1.0

ALLOWED_HOSTS=127.0.0.1,localhost,testserver
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost,http://127.0.0.1

JWT_SECRET_KEY=change-this-secret-for-production
JWT_ALGORITHM=HS256
JWT_ISSUER=decision-digital-twin
JWT_AUDIENCE=decision-digital-twin-clients
ACCESS_TOKEN_EXPIRE_MINUTES=60

MAX_FAILED_LOGINS=5
LOCKOUT_MINUTES=15
PASSWORD_MIN_LENGTH=10
RATE_LIMIT_PER_MINUTE=120
MAX_REQUEST_SIZE_MB=5

INVOICE_APPROVAL_THRESHOLD=300000
HIGH_VALUE_PAYMENT_THRESHOLD=1000000
REQUIRED_HIGH_VALUE_APPROVALS=2

DATABASE_PATH=app/data/platform_state.db
AUDIT_LOG_PATH=app/data/audit_trail.jsonl
AUDIT_HMAC_KEY=change-this-audit-signing-key
DATA_ENCRYPTION_KEY=change-this-fernet-key-or-passphrase
BACKUP_DIR=app/data/backups
BACKUP_RETENTION_COUNT=20

ENABLE_EXTERNAL_AI=auto
EXTERNAL_AI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
EXTERNAL_AI_API_KEY=
EXTERNAL_AI_MODELS=gpt-4o-mini,gpt-4.1-mini
EXTERNAL_AI_TIMEOUT_SECONDS=20

BOOTSTRAP_USERS_JSON={"admin":{"password":"Admin@12345","role":"admin"},"auditor":{"password":"Auditor@12345","role":"auditor"},"risk_analyst":{"password":"Risk@12345","role":"risk_analyst"}}
